# Maintainer: Mouser Contributors <https://github.com/TomBadash/Mouser>
pkgname=mouser-git
pkgver=3.6.0.r0.0000000
pkgrel=1
pkgdesc="Logitech HID++ mouse and keyboard companion (native Python/Qt, git HEAD)"
arch=('any')
url="https://github.com/TomBadash/Mouser"
license=('MIT')
depends=(
  'python'
  'pyside6'
  'python-hidapi'
  'python-evdev'
  'python-pillow'
  'qt6-declarative'
  'qt6-svg'
  'qt6-quickcontrols2'
)
makedepends=('git')
optdepends=(
  'kdotool: KDE Plasma Wayland per-app profile switching'
  'xdotool: X11 and XWayland foreground app detection fallback'
)
provides=('mouser')
conflicts=('mouser' 'mouser-local' 'mouser-bin')
install=mouser.install
source=(
  "git+${url}.git#branch=master"
  "package-mouser.sh"
)
sha256sums=('SKIP' 'SKIP')

pkgver() {
  cd Mouser
  local describe
  describe="$(git describe --long --tags 2>/dev/null | sed 's/^v//')"
  if [[ -n "$describe" ]]; then
    echo "$describe" | sed 's/-/./g'
    return
  fi
  local base rev short
  base="$(/usr/bin/python -c 'from core.version import APP_VERSION; print(APP_VERSION)')"
  rev="$(git rev-list --count HEAD)"
  short="$(git rev-parse --short HEAD)"
  printf '%s.r%s.%s' "$base" "$rev" "$short"
}

prepare() {
  install -Dm644 "${startdir}/package-mouser.sh" \
    "${srcdir}/Mouser/packaging/aur/package-mouser.sh"
}

check() {
  cd Mouser
  /usr/bin/python -m py_compile main_qml.py
  /usr/bin/python -m compileall -q core ui
}

package() {
  cd Mouser
  # shellcheck disable=SC1091
  . packaging/aur/package-mouser.sh
  mouser_package "$pkgdir" "$pkgver"
}